NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Supabase Dashboard → Authentication → URL configuration:
# - Site URL: e.g. http://localhost:5173 (dev) or your production origin
# - Redirect URLs: include http://localhost:5173/reset-password and https://<prod>/reset-password
#   (password reset emails use redirectTo `${origin}/reset-password` from ResetPasswordScreen.)
